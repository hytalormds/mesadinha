{
  "name": "mesadinha",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "db:create": "node scripts/create_local_db.js",
    "api:dev": "tsx watch --tsconfig tsconfig.backend.json src/server.ts",
    "api:start": "ts-node -P tsconfig.backend.json src/index.ts",
    "api:typeorm": "typeorm-ts-node-commonjs",
    "api:migration:run": "npx ts-node -P tsconfig.backend.json ./node_modules/typeorm/cli.js migration:run -d src/infra/database/typeorm/mesadinha/data-source.ts",
    "api:migration:revert": "npx ts-node -P tsconfig.backend.json ./node_modules/typeorm/cli.js migration:revert -d src/infra/database/typeorm/mesadinha/data-source.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.18.0",
    "@react-navigation/core": "^7.20.0",
    "@react-navigation/native": "^7.3.1",
    "@react-navigation/native-stack": "^7.14.10",
    "axios": "^1.16.1",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "expo": "~54.0.35",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.12",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "fastify": "^5.1.0",
    "fluent-json-schema": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.4.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "reflect-metadata": "^0.1.13",
    "typeorm": "0.3.20",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^16.11.10",
    "@types/react": "~19.1.0",
    "sqlite3": "^5.1.7",
    "ts-node": "10.9.1",
    "tsx": "^4.19.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
